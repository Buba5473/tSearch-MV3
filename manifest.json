{
  "manifest_version": 3,
  "name": "tSearch (All Trackers Edition)",
  "version": "3.6.0",
  "description": "Параллельный глобальный мультипоиск по поисковым системам и 35+ торрент-трекерам из контекстного меню с динамическим обновлением парсеров.",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
